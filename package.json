{
  "name": "hardware-pos",
  "version": "0.1.0",
  "description": "Hardware Point of Sale is a desktop application developed by Hosting Domain.",
  "author": "Hosting Domain",
  "private": true,
  "main": "start.js",
  "build": {
    "appId": "hardware-pos",
    "productName": "HardwarePOS",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!data",
      "!release",
      "!screenshots",
      "!.git"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "assets/images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "msi": {
      "oneClick": false,
      "perMachine": true
    }
  },
  "dependencies": {
    "async": "^2.6.4",
    "body-parser": "^1.18.2",
    "btoa": "^1.2.1",
    "electron-context-menu": "^0.15.1",
    "electron-store": "^5.1.0",
    "electron-winstaller": "^4.0.0",
    "express": "^4.19.2",
    "express-fileupload": "^1.1.6",
    "html2canvas": "^1.0.0-rc.5",
    "http": "0.0.0",
    "http-proxy": "^1.18.1",
    "https": "^1.0.0",
    "is-port-reachable": "^2.0.1",
    "jquery": "^3.4.1",
    "jsbarcode": "^3.11.0",
    "jspdf": "^2.3.1",
    "macaddress": "^0.2.9",
    "moment": "^2.29.4",
    "multer": "^1.4.2",
    "nedb": "^1.8.0",
    "nodemon": "^1.14.12",
    "path": "^0.12.7",
    "print-js": "^1.0.63",
    "socket.io": "^2.4.0",
    "sweetalert2": "^9.5.4",
    "xmlhttprequest": "^1.8.0"
  },
  "scripts": {
    "electron": "cross-env NODE_ENV=dev nodemon --exec \"\"electron .\"\"",
    "electron-build": "electron-builder",
    "package-win": "electron-packager . HardwarePOS --overwrite --asar=false --platform=win32 --arch=x64 --icon=assets/images/icon.ico --prune=true --out=release-builds --version-string.ProductName=\"HardwarePOS\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cross-env": "^6.0.3",
    "electron": "^22.3.25",
    "electron-builder": "^21.2.0",
    "electron-is-dev": "^1.1.0",
    "electron-packager": "^17.1.2",
    "nodemon": "^1.19.3"
  }
}
