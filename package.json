{
  "name": "metro-pos",
  "version": "0.3.0",
  "description": "MetroPOS - Point of Sale System for hardware and retail stores.",
  "author": "MetroPOS",
  "private": true,
  "main": "start.js",
  "build": {
    "appId": "metro-pos",
    "productName": "MetroPOS",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!data",
      "!release",
      "!release-builds",
      "!screenshots",
      "!.git",
      "!.gitignore",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test",
      "!node_modules/**/tests",
      "!node_modules/**/docs"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "assets/images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "msi": {
      "oneClick": false,
      "perMachine": true
    }
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "async": "^3.2.6",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.18.2",
    "btoa": "^1.2.1",
    "dompurify": "^3.4.12",
    "electron-context-menu": "^0.15.1",
    "electron-store": "^5.1.0",
    "electron-winstaller": "^5.4.4",
    "express": "^4.19.2",
    "express-fileupload": "^1.1.6",
    "html2canvas": "^1.0.0-rc.5",
    "http-proxy": "^1.18.1",
    "is-port-reachable": "^4.0.0",
    "jquery": "^4.0.0",
    "jsbarcode": "^3.11.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.3.1",
    "macaddress": "^0.5.4",
    "moment": "^2.29.4",
    "multer": "^1.4.2",
    "print-js": "^1.0.63",
    "sweetalert2": "^11.26.25"
  },
  "scripts": {
    "electron": "cross-env NODE_ENV=dev nodemon --exec \"\"electron .\"\"",
    "electron-build": "electron-builder",
    "package-win": "electron-packager . MetroPOS --overwrite --asar=false --platform=win32 --arch=x64 --icon=assets/images/icon.ico --prune=true --out=release-builds --version-string.ProductName=\"MetroPOS\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^22.3.25",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "nodemon": "^3.1.14"
  }
}
